# AI Doctor 3.0 - Environment Variables Configuration

# Application Settings
APP_NAME=AI Doctor 3.0
APP_VERSION=3.2.0
DEBUG=False

# MongoDB Configuration
# For production: Use MongoDB Atlas connection string
# Example: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=ai_doctor_db

# ⚠️ SECURITY: JWT Authentication (REQUIRED for production)
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secure-jwt-secret-here

# ⚠️ SECURITY: Admin Account (REQUIRED for production)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecureAdminPassword123!
ADMIN_NAME=System Admin

# Custom AI Endpoint Configuration
# REQUIRED: Set this to your Colab Ngrok URL or HuggingFace Inference endpoint
# The backend automatically appends /api/v1/chat/message for Colab Ngrok base URLs
# Examples:
#   Colab Ngrok (base URL only): https://your-ngrok-id.ngrok-free.dev
#   Colab Ngrok (with full path): https://your-ngrok-id.ngrok-free.dev/api/v1/chat/message
#   HuggingFace: https://api-inference.huggingface.co/models/your-model-id
CUSTOM_API_URL=https://your-ngrok-id.ngrok-free.dev/api/v1/chat/message

# Voice Service Configuration (Colab Whisper & Coqui XTTS v2)
# REQUIRED: Set this to your Colab ngrok endpoint that hosts voice services
# Endpoints provided:
#   /transcribe - Speech-to-Text (Whisper)
#   /synthesize - Text-to-Speech (Coqui XTTS v2)
VOICE_REMOTE_URL=https://your-colab-ngrok-id.ngrok-free.dev/
COQUI_REMOTE_URL=https://your-colab-ngrok-id.ngrok-free.dev/
AI_REPLY_URL=http://localhost:8000/api/v1/chat/message
AI_AUTH_TOKEN=

# OpenAI Configuration (Optional - not used if VOICE_REMOTE_URL is configured)
OPENAI_API_KEY=

# API Configuration
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
MAX_CHAT_HISTORY=100
RAZORPAY_KEY_ID - Your Razorpay API key
RAZORPAY_KEY_SECRET - Your Razorpay API secret
RAZORPAY_WEBHOOK_SECRET (optional) - For webhook
